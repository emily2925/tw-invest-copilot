# Streamlit secrets 範例 —— 部署到 Streamlit Community Cloud 時，
# 把這裡的三個值填好，貼進 Streamlit Cloud 的「App settings → Secrets」欄位。
# （本機自己跑不需要這個檔，本機用 .env 就好；這個 .example 只是清單，真實的
#  secrets.toml 已被 .gitignore 擋掉不會上傳。）

# 呼叫 Claude 產生「今日重點」用的金鑰（會花錢的部分）
ANTHROPIC_API_KEY = "sk-ant-..."

# FinMind 歷史股價資料的 token
FINMIND_API_TOKEN = "..."

# 解鎖「AI 今日重點」按鈕的密碼。
# 設了這個值 → 公開網址上別人要輸入這組密碼才能點 AI 按鈕（圖表照樣公開可看）。
# 不設 → AI 按鈕對所有人開放（本機自己用時就不必設）。
AI_UNLOCK_PASSWORD = "自己取一組密碼"
